# === LLM Provider ===
# v0.2 only supports "minimax". Future sprints may add more.
LLM_PROVIDER=minimax

# === API Keys ===
# Get your key from MiniMax; do not commit your real key.
MINIMAX_API_KEY=

# === Anthropic-SDK compatible base URL ===
# MiniMax is compatible with Anthropic's Messages API; route through this URL.
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# === Models per task ===
LLM_MODEL_MAIN=MiniMax-M3
LLM_MODEL_SUMMARIZER=MiniMax-M3

# === Generation parameters ===
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# === App ===
APP_DATA_DIR=./data
APP_LOG_LEVEL=info
