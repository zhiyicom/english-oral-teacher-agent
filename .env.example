# === LLM Provider ===
# v1.0.1: only "minimax" is enumerated but the field is not consulted by
# selectClient — keep it for forward compatibility with future providers.
LLM_PROVIDER=minimax

# === API Keys ===
# Get your key from your LLM vendor; do not commit your real key.
API_KEY=

# === Anthropic-SDK compatible base URL ===
# Any vendor that speaks Anthropic's Messages API (Anthropic, OpenRouter,
# MiniMax, etc.) can be used by pointing this URL at their endpoint.
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# === Models per task ===
LLM_MODEL_MAIN=MiniMax-M3
LLM_MODEL_SUMMARIZER=MiniMax-M3

# === Generation parameters ===
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# === Context budget (v0.7.5) ===
# Single-turn input token cap. CLI truncates oldest history when over.
# Lower = cheaper, more truncation. Higher = more context for the LLM.
# Default 6000 per PRD §5.3; valid range 1..200000.
LLM_CONTEXT_BUDGET_TOKENS=6000

# === Debug ===
# Set to 1 to log every LLM request (system prompt + messages) to data/llm-debug/
DEBUG_LOG_LLM=0

# === App ===
APP_DATA_DIR=./data
APP_LOG_LEVEL=info

# === Server (v0.8.1) ===
# HTTP listen port for `pnpm serve` (src/server.ts). CLI ignores this.
# Default 3000 per v0.8.1 scope; valid range 1..65535.
PORT=3000
