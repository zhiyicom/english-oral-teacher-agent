# === LLM Provider ===
# Choose one: anthropic | openai
LLM_PROVIDER=anthropic

# === API Keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Models per task ===
# Different tasks can use different models.
# Main agent uses the most capable; summarizer / embedding can be cheaper.
LLM_MODEL_MAIN=claude-sonnet-4-6
LLM_MODEL_SUMMARIZER=claude-sonnet-4-6
LLM_MODEL_EMBEDDING=text-embedding-3-small
LLM_EMBEDDING_PROVIDER=openai

# === Generation parameters ===
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# === App ===
APP_PORT=3000
APP_LOG_LEVEL=info
APP_DATA_DIR=./data
APP_TTS_ENGINE=web-speech
