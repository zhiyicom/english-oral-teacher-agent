# === LLM wire format (v1.0.8 §1.7) ===
# 'anthropic' — uses @anthropic-ai/sdk with x-api-key header and /v1/messages
#   (Anthropic, OpenRouter, MiniMax, etc.)
# 'openai' — uses fetch with Authorization: Bearer and /chat/completions
#   (DeepSeek, OpenAI, OpenRouter, Together, etc.)
API_STYLE=anthropic

# === API Keys ===
# Get your key from your LLM vendor; do not commit your real key.
API_KEY=

# === LLM base URL ===
# - API_STYLE=anthropic: any vendor that speaks Anthropic's Messages API
#   (Anthropic, OpenRouter, MiniMax, etc.) — set this to their endpoint.
# - API_STYLE=openai: any vendor that speaks OpenAI's Chat Completions API
#   (DeepSeek, OpenAI, OpenRouter, etc.) — set this to their /v1 base.
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# === Models per task ===
LLM_MODEL_MAIN=MiniMax-M3
LLM_MODEL_SUMMARIZER=MiniMax-M3

# === Generation parameters ===
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# === Context budget (v0.7.5) ===
# Single-turn input token cap. CLI truncates oldest history when over.
# Lower = cheaper, more truncation. Higher = more context for the LLM.
# Default 6000 per PRD §5.3; valid range 1..200000.
LLM_CONTEXT_BUDGET_TOKENS=6000

# === Debug ===
# Set to 1 to log every LLM request (system prompt + messages) to data/llm-debug/
DEBUG_LOG_LLM=0
RUN_LIVE_LLM=1

# === App ===
APP_DATA_DIR=./data
APP_LOG_LEVEL=info

# === Server (v0.8.1) ===
# HTTP listen port for `pnpm serve` (src/server.ts). CLI ignores this.
# Default 8787 per v1.0.6 scope; valid range 1..65535.
PORT=8787
