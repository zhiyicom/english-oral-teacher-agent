# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Runtime data (NEVER commit student data) — `data/*` not `data/`, so
# the !data/topics-default.json exception below can re-include the JSON
# (a `!` rule cannot un-ignore a file inside an ignored directory).
data/*
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# v1.0.5 §C — checked-in default topic library (project asset, not user data)
!data/topics-default.json

# Per-instance user config (real student profile)
prompts/USER.md

# Secrets
.env
.env.local
.env.*.local
*.pem
*.key

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# Web build artifacts (v0.8.2)
web/dist/
web/node_modules/
web/.vite/

# Playwright (v0.8.2)
test-results/
playwright-report/
tests/e2e/.auth/
